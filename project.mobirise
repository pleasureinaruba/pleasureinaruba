ext-white text-primary\" href=\"pleasure-in-aruba-escorts.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\">\n                            Pleasure Escorts<br></a></li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"https://pleasureinaruba.com/services-pleasure-in-aruba-escort\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\">Escort Services</a></li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"https://pleasureinarubaescort.netlify.app/pleasure-in-aruba-contact-us\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Contact us</a></li></ul>\n                <div class=\"icons-menu\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://hot.com/@pleasureinarubaescorts\" target=\"_blank\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont material material-whatshot\" style=\"color: rgb(209, 164, 81); fill: rgb(209, 164, 81);\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://www.youtube.com/@pleasureinaruba\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont social-icon-youtube social-icon\" style=\"color: rgb(209, 164, 81); fill: rgb(209, 164, 81);\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n                    </